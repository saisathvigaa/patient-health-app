# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/patient_health

# ─── JWT Auth ───
SECRET_KEY=change-me-run-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Google Cloud Vision ───
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ─── File Storage ───
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── CORS ───
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ─── App ───
APP_NAME=Patient Health Dashboard
DEBUG=true
