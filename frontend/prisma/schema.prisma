generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  hashedPassword String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  patients      Patient[]
}

model Patient {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  dateOfBirth DateTime?
  gender      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reports     Report[]
}

model Report {
  id          String     @id @default(uuid())
  patientId   String
  patient     Patient    @relation(fields: [patientId], references: [id])
  reportDate  DateTime
  labName     String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  labValues   LabValue[]
  prescriptions Prescription[]
}

model LabValue {
  id        String  @id @default(uuid())
  reportId  String
  report    Report  @relation(fields: [reportId], references: [id])
  name      String
  value     Float
  unit      String?
  refMin    Float?
  refMax    Float?
}

model Prescription {
  id          String       @id @default(uuid())
  reportId    String
  report      Report       @relation(fields: [reportId], references: [id])
  doctorName  String?
  notes       String?
  createdAt   DateTime     @default(now())
  medications Medication[]
}

model Medication {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  name           String
  dosage         String?
  frequency      String?
}
